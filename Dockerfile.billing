FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080 \
    PYTHONPATH=/app

WORKDIR /app

COPY requirements-billing.txt /app/requirements-billing.txt
RUN python3 -m pip install --no-cache-dir --upgrade pip && \
    python3 -m pip install --no-cache-dir -r /app/requirements-billing.txt

COPY src /app/src

CMD ["python3", "-m", "uvicorn", "src.backend.billing_api:app", "--host", "0.0.0.0", "--port", "8080", "--log-level", "info", "--access-log"]

APP_ENV=prod
BACKEND_LOG_LEVEL=info
LOG_JSON=1
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
OPENBLAS_NUM_THREADS=4
NUMEXPR_NUM_THREADS=4
ORT_INTRA_OP_NUM_THREADS=4
ORT_INTER_OP_NUM_THREADS=2
MCP_GPU_DEVICE=cuda
BACKEND_AUTH_DISABLED=false
BACKEND_USE_STORAGE=true
CORS_ALLOW_ORIGINS=https://app.sightsinger.app,https://sightsinger.app,https://sightsinger-app.web.app,https://sightsinger-app.firebaseapp.com
STORAGE_BUCKET=sightsinger-app.firebasestorage.app
VOICEBANK_BUCKET=sightsinger-app.firebasestorage.app
VOICEBANK_PREFIX=assets/voicebanks
PROJECT_ID=sightsinger-app
BACKEND_MAX_UPLOAD_MB=5
BACKEND_MAX_MXL_UNCOMPRESSED_MB=20
# Secret Manager identifier + version. Do not commit the real secret value here.
BACKEND_PLAYBACK_TOKEN_SECRET=BACKEND_PLAYBACK_TOKEN_SECRET
BACKEND_PLAYBACK_TOKEN_SECRET_VERSION=latest
BACKEND_PLAYBACK_TOKEN_TTL_SECONDS=300
BREVO_WAITLIST_LIST_ID=3
BREVO_DOI_TEMPLATE_ID=1
BREVO_DOI_REDIRECT_URL=https://sightsinger.app/waitlist/confirmed
BREVO_WAITLIST_TIMEOUT_SECONDS=10
BREVO_WAITLIST_MAX_ATTEMPTS=2
BREVO_WAITLIST_RETRY_BASE_DELAY_SECONDS=0.25
BREVO_WAITLIST_RETRY_JITTER_SECONDS=0.1
CREDIT_RETRY_MAX_ATTEMPTS=3
CREDIT_RETRY_BASE_DELAY_SECONDS=0.5
CREDIT_RETRY_TEST_RELEASE_FAIL_COUNT=0
BREVO_WAITLIST_API_KEY_SECRET=BREVO_WAITLIST_API_KEY
BREVO_WAITLIST_API_KEY_SECRET_VERSION=latest
VOICE_PART_MIN_WORD_LYRIC_COVERAGE_RATIO=0.15
VOICE_PART_MIN_WORD_LYRIC_WARN_FLOOR_RATIO=0.75
VOICE_PART_WEAK_LYRIC_SOURCE_MAX_WORD_RATIO=0.35
VOICE_PART_WEAK_LYRIC_SOURCE_MIN_RATIO_DELTA=0.25
VOICE_PART_WEAK_LYRIC_SOURCE_MIN_WORD_DELTA=2
VOICE_PART_CROSS_STAFF_LOCAL_MIN_WORD_RATIO=0.6
VOICE_PART_CROSS_STAFF_LOCAL_MIN_RATIO_DELTA=0.35
VOICE_PART_CROSS_STAFF_LOCAL_MIN_WORD_DELTA=3
VOICE_PART_CROSS_STAFF_DONOR_MIN_WORD_RATIO=0.6
VOICE_PART_CROSS_STAFF_DONOR_MIN_RATIO_DELTA=0.3
VOICE_PART_CROSS_STAFF_DONOR_MIN_WORD_DELTA=3
VOICE_PART_REPAIR_MAX_RETRIES=2
SYLLABLE_ALIGNER_V2=1
SYLLABLE_TIMING_V2=1
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=180
GEMINI_THINKING_LEVEL=
GEMINI_INCLUDE_THOUGHT_SUMMARY=0
GEMINI_PROMPT_CACHE_ENABLED=true
GEMINI_PROMPT_CACHE_TTL_DAYS=3650
GEMINI_PROMPT_CACHE_DELETE_STALE=true
INJECT_FULL_PARSED_SCORE_JSON=0
PREPROCESS_MAX_ATTEMPTS=3

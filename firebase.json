{
  "firestore": {
    "database": "(default)",
    "location": "eur3",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
 "hosting": {
  "public": "ui/dist",
  "ignore": [
    "firebase.json",
    "**/.*",
    "**/node_modules/**"
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/faq",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/pricing",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/learn",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/learn/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/tools",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/tools/**",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/waitlist/confirmed",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/what-it-does",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/who-for",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/__/auth/**",
      "destination": "/__/auth/handler"
    },
    {
      "source": "/__/firebase/**",
      "destination": "/__/firebase/init.json"
    },
    {
      "source": "/sessions/**",
      "run": {
        "serviceId": "sightsinger-api",
        "region": "us-east4"
      }
    },
    {
      "source": "/credits",
      "run": {
        "serviceId": "sightsinger-api",
        "region": "us-east4"
      }
    },
    {
      "source": "/billing/**",
      "run": {
        "serviceId": "sightsinger-api",
        "region": "us-east4"
      }
    },
    {
      "source": "/waitlist/subscribe",
      "run": {
        "serviceId": "sightsinger-api",
        "region": "us-east4"
      }
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/app/**",
      "destination": "/app.html"
    },
    {
      "source": "/demo",
      "destination": "/app.html"
    },
    {
      "source": "/demo/**",
      "destination": "/app.html"
    },
    {
      "source": "**",
      "run": {
        "serviceId": "sightsinger-marketing-be",
        "region": "us-east4"
      }
    }
  ]
},
  "storage": {
    "rules": "storage.rules"
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "apphosting": {
      "startCommand": "npm --prefix marketing run dev"
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  },
  "apphosting": [
    {
      "backendId": "sightsinger-marketing-be",
      "rootDir": "/",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "functions"
      ]
    }
  ]
}

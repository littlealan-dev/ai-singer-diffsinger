rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isNonAnonymousUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    match /users/{uid} {
      allow read: if isNonAnonymousUser() && request.auth.uid == uid;
      // Allow users to update their own notification metadata, but nothing else. 
      // Credits are managed by the server.
      allow update: if isNonAnonymousUser() && request.auth.uid == uid 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['metadata']);
      allow create, delete: if false; 
    }

    match /app_config/maintenance {
      allow read: if false;
      allow write: if false;
    }

    match /credit_reservations/{jobId} {
      allow read: if isNonAnonymousUser() && resource.data.userId == request.auth.uid;
      allow write: if false; 
    }

    match /jobs/{jobId} {
      allow create: if isNonAnonymousUser()
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isNonAnonymousUser()
                    && resource.data.userId == request.auth.uid;
    }
  }
}
